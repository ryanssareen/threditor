# Firebase Admin SDK — service account credentials. NOT NEXT_PUBLIC_.
# Copy literal values from your service-account JSON; the FIREBASE_ADMIN_PRIVATE_KEY
# value should keep its `\n` escapes (admin.ts normalizes them at runtime).
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Public Firebase config — for the client SDK.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Supabase — for skin storage.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# M16 — AI Skin Generation.
#
# GROQ_API_KEY: Groq Cloud API key. Starts with `gsk_`. Free tier is sufficient
# for M16's projected traffic (≤100 active users × ≤5 gens/hr). No quotes;
# Vercel env-paste sometimes preserves them. Generate at https://console.groq.com/keys.
GROQ_API_KEY=

# IP_HASH_SALT: ≥32-char hex string used to one-way-hash client IPs into
# rate-limit doc IDs. MUST NOT be rotated post-launch without a corresponding
# /rateLimits collection purge — rotating mid-window orphans existing per-IP
# buckets and lets one IP exceed the cap by 2× during the rollover.
# Generate with: openssl rand -hex 32
IP_HASH_SALT=

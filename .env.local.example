# Firebase Admin SDK — service account credentials. NOT NEXT_PUBLIC_.
# Copy literal values from your service-account JSON; the FIREBASE_ADMIN_PRIVATE_KEY
# value should keep its `\n` escapes (admin.ts normalizes them at runtime).
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Public Firebase config — for the client SDK.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Supabase — for skin storage.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# M16 — AI Skin Generation.
#
# GROQ_API_KEY: Groq Cloud API key. Starts with `gsk_`. Free tier is sufficient
# for M16's projected traffic (≤100 active users × ≤5 gens/hr). No quotes;
# Vercel env-paste sometimes preserves them. Generate at https://console.groq.com/keys.
GROQ_API_KEY=

# IP_HASH_SALT: ≥32-char hex string used to one-way-hash client IPs into
# rate-limit doc IDs. MUST NOT be rotated post-launch without a corresponding
# /rateLimits collection purge — rotating mid-window orphans existing per-IP
# buckets and lets one IP exceed the cap by 2× during the rollover.
# Generate with: openssl rand -hex 32
IP_HASH_SALT=

# M17 — Cloudflare Workers AI image generation (SDXL Lightning).
#
# AI_PROVIDER: which AI backend the /api/ai/generate route uses. Code default
# is `groq` so a missing env value falls back to the known-working M16 path.
# Operators flip per environment (preview first, then production) after a
# manual smoke test against the deployed Worker. Reverting is a Vercel env
# change, no redeploy needed.
AI_PROVIDER=groq

# CLOUDFLARE_WORKER_URL: full URL of the deployed `ai-skin-generator` Worker.
# No trailing slash. After `wrangler deploy` from the workers/ directory,
# copy the printed URL into this var across every Vercel environment.
# Example: https://ai-skin-generator.<account>.workers.dev
CLOUDFLARE_WORKER_URL=

# CLOUDFLARE_WORKER_TOKEN: bearer token shared with the Worker's SDXL_TOKEN
# secret. The Worker rejects any request whose Authorization header does not
# match. Set on the Worker side via `wrangler secret put SDXL_TOKEN`. Rotation
# cadence is 90 days minimum; the Worker accepts SDXL_TOKEN_PREVIOUS during
# the rotation window for zero-downtime swaps. See workers/README.md.
CLOUDFLARE_WORKER_TOKEN=

# Brevo (formerly Sendinblue) — transactional email API for the landing
# page contact form. Server-only; never NEXT_PUBLIC_. Generate at
# https://app.brevo.com/settings/keys/api.
BREVO_API_KEY=

# Address contact-form submissions are delivered to.
CONTACT_TO_EMAIL=

# `from` address used when calling Brevo. The single sender or domain
# MUST be verified in your Brevo dashboard or the API rejects with 400.
CONTACT_FROM_EMAIL=
CONTACT_FROM_NAME=Threditor Contact Form

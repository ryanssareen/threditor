// M9 Unit 5: Firestore security rules per DESIGN.md §11.5.
//
// Deployment (manual — requires a Firebase project):
//   firebase login
//   firebase deploy --only firestore:rules
//
// Testing (deferred to an emulator-based CI run):
//   Install @firebase/rules-unit-testing and run the Firebase Emulator
//   Suite. Rules logic tests live under tests/firestore-rules.test.ts
//   once the emulator is wired. M9 ships the rules file; runtime
//   verification is M10's responsibility (first real auth + write path).

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── /users/{uid} — public profiles ──────────────────────────────
    match /users/{uid} {
      allow read: if true;

      allow create: if isOwner(uid)
                    && request.resource.data.uid == uid
                    && request.resource.data.skinCount == 0;

      allow update: if isOwner(uid)
                    && !('skinCount' in request.resource.data.diff(resource.data).affectedKeys());

      allow delete: if false;
    }

    // ── /skins/{skinId} — public gallery entries ────────────────────
    match /skins/{skinId} {
      allow read: if true;

      allow create: if isSignedIn()
                    && request.resource.data.ownerUid == request.auth.uid
                    && request.resource.data.likeCount == 0
                    && 'tags' in request.resource.data
                    && request.resource.data.tags.size() <= 8;

      allow update: if isOwner(resource.data.ownerUid)
                    && !('likeCount' in request.resource.data.diff(resource.data).affectedKeys())
                    && !('ownerUid' in request.resource.data.diff(resource.data).affectedKeys());

      allow delete: if isOwner(resource.data.ownerUid);
    }

    // ── /likes/{likeId} — one doc per (skin, user) pair ─────────────
    //
    // Doc id convention: `${skinId}_${uid}` so each (skin, user) pair
    // is uniquely addressable. The create rule enforces this at the
    // rules level so the uniqueness invariant doesn't live only in
    // client code — a second create at the same path fails with
    // "already exists", preventing like-count inflation.
    //
    // Delete checks `resource.data.uid` (the existing doc) because
    // `request.resource` is null on delete and accessing it would
    // always deny.
    match /likes/{likeId} {
      allow read: if true;
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid
                    && likeId == request.resource.data.skinId + '_' + request.auth.uid;
      allow delete: if isSignedIn()
                    && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // ── /aiGenerations/{docId} — M16 AI generation logs ─────────────
    //
    // Server-only. Written by the Admin SDK from /api/ai/generate.
    // Holds the verbatim prompt (with light PII redaction), token
    // counts, costEstimate, and ipHash for retrospective abuse review.
    // TTL policy on `expireAt` (now + 90 days) sweeps stale docs.
    //
    // Admin SDK bypasses these rules; the deny-all stance is the
    // belt-and-suspenders guarantee that no client code can read prompt
    // text or co-locate uid+ipHash for retroactive deanonymization.
    match /aiGenerations/{docId} {
      allow read, write: if false;
    }

    // ── /rateLimits/{docId} — M16 per-user / per-IP rate buckets ────
    //
    // Doc-id conventions:
    //   {uid}_{YYYYMMDDHH}            — per-user hourly bucket
    //   {uid}_day_{YYYYMMDD}          — per-user daily bucket
    //   ip_{ipHash}_{YYYYMMDDHH}      — per-IP hourly bucket
    //
    // Counters use FieldValue.increment inside db.runTransaction so
    // concurrent generations cannot race past the gate. TTL policy on
    // `expireAt` sweeps stale docs (now + 26h covers both hour and day
    // buckets with buffer).
    //
    // Server-only — admin SDK bypasses; clients denied so they cannot
    // spoof a doc ID and reset their own counter.
    match /rateLimits/{docId} {
      allow read, write: if false;
    }

    // ── /aiConfig/{docId} — M16 aggregate-cost kill switch ───────────
    //
    // Single doc /aiConfig/global with shape:
    //   { enabled: boolean, todayTokens: number, todayDate: 'YYYYMMDD' }
    //
    // Read inside the rate-limit transaction. If `enabled === false` OR
    // `todayTokens > AGGREGATE_TOKEN_CAP`, the route returns 503 with
    // no per-user counter increment. Operator flips `enabled` in
    // Firebase Console for sub-minute incident response.
    match /aiConfig/{docId} {
      allow read, write: if false;
    }
  }
}
